# BetterLinks Free E2E — environment template
# Copy to .env and fill in your values; .env is gitignored.

# Base URL of the target WordPress site (no trailing slash)
BASE_URL=http://localhost:8080

# WordPress admin credentials used by tests/auth.setup.js
# Either a username or an email works, as long as the user has `manage_options`.
ADMIN_USER=admin
ADMIN_PASS=admin

# Optional: prefix for test-created slugs (keeps cleanup scoped)
TEST_SLUG_PREFIX=e2ef
